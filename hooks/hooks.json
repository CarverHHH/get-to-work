{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/run-node.sh",
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start.js"
            ],
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/run-node.sh",
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate-command.js"
            ],
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/run-node.sh",
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/protect-files.js"
            ],
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/run-node.sh",
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/format-file.js"
            ],
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/run-node.sh",
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/suggest-compact.js"
            ],
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/run-node.sh",
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/observe-patterns.js"
            ],
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/run-node.sh",
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/knowledge-prompt.js"
            ],
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/run-node.sh",
              "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-compact.js"
            ],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
